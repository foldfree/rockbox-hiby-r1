 #endif
@@ -670,6 +831,41 @@ static void sink_dma_start(const void *addr, size_t size)
     pcm_data = addr;
     pcm_size = size;
 
+    /* Reopen if there is no open handle, or if the configured playback
+     * device no longer matches the open one. A route switch (e.g. to a
+     * Bluetooth sink) updates playback_dev and may close the handle,
+     * expecting the next start to reopen on the new device; the device is
+     * otherwise only opened in sink_dma_init(). Handling it here makes the
+     * switch take effect on the very next buffer (covers both "switched
+     * while playing" and "connected then pressed play" orderings) and
+     * avoids dereferencing a NULL handle below. */
+    if (!handle || !current_alsa_device || !playback_dev ||
+        strcmp(playback_dev, current_alsa_device) != 0)
+    {
+        unsigned long sampr;
+
+        open_hwdev(playback_dev, SND_PCM_STREAM_PLAYBACK);
+        if (!handle)
+        {
+            return;
+        }

+         * back to the default freq). */
+        sampr = real_sample_rate ? real_sample_rate
+                                 : hw_freq_sampr[HW_FREQ_DEFAULT];
+        set_hwparams(handle, sampr);
+        set_swparams(handle);
+        last_sample_rate = sampr;
+    }
